# ─── Clerk ────────────────────────────────────────────────────────────────────
# Create an application at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (leave as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Create a database at https://neon.tech (or via Vercel Marketplace)
DATABASE_URL=postgresql://...

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Create a database at https://console.upstash.com (or via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ─── Google Places API ────────────────────────────────────────────────────────
# Enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=AIza...

# ─── Anthropic ───────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
